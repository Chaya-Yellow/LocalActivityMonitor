<Window x:Class="ActivityMonitor.TrayApp.ReportEditor.ReportEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="日报编辑器"
        Height="650" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <!-- 头部：日期导航 -->
            <RowDefinition Height="Auto" />
            <!-- 状态栏 -->
            <RowDefinition Height="Auto" />
            <!-- 编辑器 -->
            <RowDefinition Height="*" />
            <!-- 底部操作栏 -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════ 日期导航 ═══════ -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="◀ 前一天"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource TextSecondaryBrush}"
                    Command="{Binding PreviousDayCommand}"
                    Padding="10,4" FontSize="12" />

            <TextBlock Grid.Column="1"
                       Text="{Binding DateLabel}"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0" />

            <Button Grid.Column="3" Content="后一天 ▶"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource TextSecondaryBrush}"
                    Command="{Binding NextDayCommand}"
                    Padding="10,4" FontSize="12"
                    Margin="0,0,6,0" />

            <Button Grid.Column="4" Content="🔄 重新生成"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource WarningBrush}"
                    Command="{Binding RegenerateReportCommand}"
                    Padding="10,4" FontSize="12" />
        </Grid>

        <!-- ═══════ 状态信息 ═══════ -->
        <Border Grid.Row="1"
                Margin="0,0,0,6"
                Padding="8,4"
                CornerRadius="4"
                BorderThickness="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E8F5E9" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExportSuccess}" Value="False">
                            <Setter Property="Background" Value="#FFF3E0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <!-- ═══════ Markdown 编辑器 ═══════ -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <TextBox Text="{Binding ReportMarkdown, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Consolas"
                     FontSize="13"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Padding="10"
                     SpellCheck.IsEnabled="False"
                     IsReadOnly="False" />
        </Border>

        <!-- ═══════ 底部操作栏 ═══════ -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Exporting 进度指示 -->
            <TextBlock Grid.Column="0"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="编辑完成后，点击导出按钮。" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExporting}" Value="True">
                                <Setter Property="Text" Value="⏳ 正在导出..." />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 操作日志预览按钮：手动查看窗口切换记录 -->
            <Button Grid.Column="1"
                    Content="📋 操作日志"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource WarningBrush}"
                    Command="{Binding ShowLogPreviewCommand}"
                    Margin="0,0,6,0"
                    Padding="12,6"
                    ToolTip="预览当日的操作日志（窗口切换记录）" />

            <Button Grid.Column="2"
                    Content="📋 复制到剪贴板"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource PrimaryBrush}"
                    Command="{Binding CopyToClipboardCommand}"
                    Margin="0,0,8,0"
                    Padding="12,6" />

            <Button Grid.Column="3"
                    Content="💾 导出为 .md"
                    Background="{StaticResource SuccessBrush}"
                    Command="{Binding ExportToFileCommand}"
                    Padding="12,6">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="IsEnabled" Value="True" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExporting}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            <Button Grid.Column="4"
                    Content="关闭"
                    Style="{StaticResource PrimaryButton}"
                    Background="#666666"
                    Margin="8,0,0,0"
                    Padding="12,6"
                    Click="OnCloseClick" />
        </Grid>
    </Grid>
</Window>
