<Window x:Class="ActivityMonitor.TrayApp.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置"
        Height="450" Width="520"
        MinHeight="350" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════ 标题 ═══════ -->
        <TextBlock Grid.Row="0"
                   Text="⚙ 设置"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,14" />

        <!-- ═══════ 设置选项 ═══════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 空闲阈值 -->
                <Border Style="{StaticResource CardBorder}" Padding="14,10" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="空闲检测阈值"
                                   FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="超过此时间无键盘/鼠标输入则判定为空闲。"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" />

                        <Grid Grid.Column="1" Grid.RowSpan="2"
                              VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding IdleThresholdMinutes}"
                                     Width="60" TextAlignment="Center"
                                     Margin="0,0,4,0" />
                            <TextBlock Grid.Column="1"
                                       Text="分钟"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- 数据保留 -->
                <Border Style="{StaticResource CardBorder}" Padding="14,10" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="数据保留策略"
                                   FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="超出保留期限的历史数据将被自动清理。"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" />

                        <ComboBox Grid.Column="1" Grid.RowSpan="2"
                                  ItemsSource="{Binding RetentionOptions}"
                                  SelectedIndex="{Binding RetentionIndex}"
                                  Width="120"
                                  VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- 开机自启 -->
                <Border Style="{StaticResource CardBorder}" Padding="14,10" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="开机自启"
                                   FontSize="14" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="系统启动时自动运行 Activity Monitor。"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" />

                        <CheckBox Grid.Column="1" Grid.RowSpan="2"
                                  IsChecked="{Binding AutoStart}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0" />
                    </Grid>
                </Border>

                <!-- 危险操作 -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="14,10"
                        Margin="0,0,0,8"
                        BorderBrush="{StaticResource DangerBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="清除所有数据"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="{StaticResource DangerBrush}" />
                            <TextBlock Text="删除所有历史活动记录和统计数据，此操作不可撤销。"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="🗑 清除"
                                Background="{StaticResource DangerBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                CornerRadius="4"
                                Padding="14,6"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Command="{Binding ClearAllDataCommand}" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══════ 状态信息 ═══════ -->
        <Border Grid.Row="2"
                Margin="0,8,0,0"
                Padding="8,4"
                CornerRadius="4"
                BorderThickness="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E8F5E9" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                            <Setter Property="Background" Value="#FFF3E0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </Border>

        <!-- ═══════ 底部按钮 ═══════ -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="↺ 恢复默认"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource TextSecondaryBrush}"
                    Command="{Binding ResetDefaultsCommand}"
                    Margin="0,0,8,0" />

            <Button Grid.Column="2"
                    Content="💾 保存设置"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource SuccessBrush}"
                    Command="{Binding SaveSettingsCommand}"
                    Margin="0,0,8,0" />

            <Button Grid.Column="3"
                    Content="关闭"
                    Style="{StaticResource PrimaryButton}"
                    Background="#666666"
                    Padding="14,6"
                    Click="OnCloseClick" />
        </Grid>
    </Grid>
</Window>
