<UserControl x:Class="ActivityMonitor.TrayApp.History.Controls.BarChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:ActivityMonitor.TrayApp.History.Controls"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="500">

    <!-- 自定义水平柱状图控件，使用 Rectangle + ItemsControl 实现 -->

    <UserControl.Resources>
        <!-- 柱状图单项模板 -->
        <DataTemplate x:Key="BarItemTemplate" DataType="controls:BarChartItem">
            <Grid MinHeight="28" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <!-- 软件名称（固定宽度） -->
                    <ColumnDefinition Width="100" />
                    <!-- 柱状图区域（自适应） -->
                    <ColumnDefinition Width="*" />
                    <!-- 百分比文本（固定宽度） -->
                    <ColumnDefinition Width="60" />
                </Grid.ColumnDefinitions>

                <!-- 软件名称 -->
                <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           FontSize="11"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,6,0"
                           ToolTip="{Binding Name}" />

                <!-- 柱状图区域：包括柱子 + 时长标签 -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <!-- 背景参考线（灰色细线，表示100%基准） -->
                    <Border Height="1"
                            Background="#E0E0E0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Stretch" />

                    <!-- 柱子矩形 -->
                    <Rectangle Height="18"
                               RadiusX="3" RadiusY="3"
                               Fill="{Binding BarColor}"
                               HorizontalAlignment="Left"
                               ToolTip="{Binding TooltipText}">
                        <Rectangle.Width>
                            <MultiBinding Converter="{StaticResource BarWidthConverter}">
                                <Binding Path="WidthFactor" />
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                            </MultiBinding>
                        </Rectangle.Width>
                    </Rectangle>

                    <!-- 时长标签（显示在柱子后方，避免柱子太短时文字被裁剪） -->
                    <TextBlock Text="{Binding FormattedDuration}"
                               FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"
                               ToolTip="{Binding TooltipText}" />
                </Grid>

                <!-- 百分比文本 -->
                <TextBlock Grid.Column="2"
                           Text="{Binding FormattedPercentage}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="6,0,0,0" />
            </Grid>
        </DataTemplate>

        <!-- 宽度转换器：WidthFactor * parentActualWidth -->
        <controls:BarWidthMultiConverter x:Key="BarWidthConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 柱状图标题栏 -->
            <RowDefinition Height="Auto" />
            <!-- 柱状图内容区 -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <TextBlock Grid.Row="0"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,6">
            <Run Text="{Binding ChartTitle, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <Run Text=" · 软件时长分布" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
        </TextBlock>

        <!-- 柱状图列 -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="BarItemsControl"
                          ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          ItemTemplate="{StaticResource BarItemTemplate}" />
        </ScrollViewer>

        <!-- 空数据提示 -->
        <TextBlock Grid.Row="1"
                   Text="暂无统计数据"
                   FontSize="13"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"
                   x:Name="EmptyLabel" />
    </Grid>
</UserControl>
