<Window x:Class="ActivityMonitor.TrayApp.History.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:ActivityMonitor.TrayApp.Dashboard.Controls"
        xmlns:models="clr-namespace:ActivityMonitor.Core.Models;assembly=ActivityMonitor.Core"
        mc:Ignorable="d"
        Title="历史记录"
        Height="600" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}">

    <Window.Resources>
        <!-- 时间线视图的事件列表模板 -->
        <DataTemplate x:Key="TimelineEventTemplate" DataType="models:ActivityEvent">
            <Border Style="{StaticResource CardBorder}"
                    Padding="8,6"
                    Margin="0,2"
                    BorderThickness="0"
                    Cursor="Hand"
                    Background="#FAFAFA">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 时间 -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" MinWidth="70">
                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}">
                            <Run Text="{Binding StartTime, StringFormat={}{0:HH:mm}}" />
                        </TextBlock>
                        <TextBlock FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="{Binding EndTime, StringFormat={}{0:HH:mm}}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- 标题和详情 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                        <TextBlock Text="{Binding WindowTitle}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding ProcessName}" />
                            <Run Text=" · " />
                            <Run Text="{Binding Category}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- 时长 -->
                    <TextBlock Grid.Column="2"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding DurationMs, StringFormat={}{0:N0}ms}" />
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <!-- 头部：导航 + DatePicker -->
            <RowDefinition Height="Auto" />
            <!-- 范围选择模式（多日期） -->
            <RowDefinition Height="Auto" />
            <!-- 摘要信息 -->
            <RowDefinition Height="Auto" />
            <!-- 空数据提示 -->
            <RowDefinition Height="Auto" />
            <!-- 内容区：事件列表 / 统计概览 -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════ 日期导航 + DatePicker ═══════ -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="◀"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource TextSecondaryBrush}"
                    Command="{Binding PreviousDayCommand}"
                    Width="32" Height="28"
                    FontSize="14" Padding="0" />

            <TextBlock Grid.Column="1"
                       Text="{Binding DateLabel}"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="10,0" />

            <Button Grid.Column="2" Content="▶"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource TextSecondaryBrush}"
                    Command="{Binding NextDayCommand}"
                    Width="32" Height="28"
                    FontSize="14" Padding="0"
                    Margin="0,0,8,0" />

            <!-- DatePicker 日历控件 -->
            <DatePicker x:Name="DatePickerControl"
                        Grid.Column="3"
                        SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                        FontSize="12"
                        Height="28"
                        Width="130"
                        HorizontalAlignment="Left"
                        Margin="4,0,0,0">
                <DatePicker.Resources>
                    <Style TargetType="DatePickerTextBox">
                        <Setter Property="IsReadOnly" Value="True" />
                    </Style>
                </DatePicker.Resources>
            </DatePicker>

            <Button Grid.Column="4" Content="今天"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource PrimaryBrush}"
                    Command="{Binding GoToTodayCommand}"
                    Padding="10,4" FontSize="12"
                    Margin="6,0,0,0" />

            <Button Grid.Column="5" Content="📅 范围选择"
                    Style="{StaticResource PrimaryButton}"
                    Background="{StaticResource WarningBrush}"
                    Command="{Binding ToggleRangeModeCommand}"
                    Padding="10,4" FontSize="11"
                    Margin="6,0,0,0" />

            <TextBlock Grid.Column="6"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0">
                <Run Text="{Binding TotalActiveText}" />
                <Run Text=" · " />
                <Run Text="{Binding EventCountText}" />
            </TextBlock>
        </Grid>

        <!-- ═══════ 范围选择模式（多日期） ═══════ -->
        <Border Grid.Row="1"
                Margin="0,0,0,8"
                Padding="10,6"
                CornerRadius="6"
                BorderThickness="0"
                Background="#FFF8E1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRangeMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="从"
                           FontSize="12" VerticalAlignment="Center"
                           Margin="0,0,4,0" />
                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding RangeStart, Mode=TwoWay}"
                            FontSize="12" Height="26" Width="120" />
                <TextBlock Grid.Column="2" Text="到"
                           FontSize="12" VerticalAlignment="Center"
                           Margin="8,0,4,0" />
                <DatePicker Grid.Column="3"
                            SelectedDate="{Binding RangeEnd, Mode=TwoWay}"
                            FontSize="12" Height="26" Width="120" />

                <Button Grid.Column="5"
                        Content="📊 查看统计"
                        Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource SuccessBrush}"
                        Command="{Binding LoadRangeStatsCommand}"
                        Padding="10,4" FontSize="11"
                        Margin="8,0,0,0" />

                <Button Grid.Column="6"
                        Content="❌ 退出范围"
                        Style="{StaticResource PrimaryButton}"
                        Background="#666666"
                        Command="{Binding ToggleRangeModeCommand}"
                        Padding="10,4" FontSize="11"
                        Margin="6,0,0,0" />
            </Grid>
        </Border>

        <!-- ═══════ 范围统计摘要 ═══════ -->
        <Border Grid.Row="2"
                Margin="0,0,0,6"
                Padding="8,4"
                CornerRadius="4"
                BorderThickness="0"
                Background="#E8F5E9">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsRangeMode}" Value="True" />
                                <Condition Binding="{Binding HasData}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="12" Foreground="{StaticResource TextPrimaryBrush}">
                    <Run Text="📊 范围统计：" />
                    <Run Text="{Binding RangeDaysText}" />
                    <Run Text=" · 总活跃：" />
                    <Run Text="{Binding RangeTotalText}" />
                    <Run Text=" · 日均：" />
                    <Run Text="{Binding RangeDailyAvgText}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══════ 空数据提示 ═══════ -->
        <Border Grid.Row="3"
                Margin="0,0,0,8"
                Padding="20,12"
                CornerRadius="6"
                Background="#FFF8E1"
                BorderThickness="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasData}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding EmptyMessage}"
                       FontSize="14"
                       Foreground="{StaticResource WarningBrush}"
                       HorizontalAlignment="Center" />
        </Border>

        <!-- ═══════ 内容区：时间线视图 ═══════ -->
        <Border Grid.Row="4" Padding="0"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsTimelineView}" Value="True" />
                                <Condition Binding="{Binding HasData}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding DateEvents}"
                              ItemTemplate="{StaticResource TimelineEventTemplate}"
                              Margin="8"
                              VirtualizingPanel.IsVirtualizing="True" />
            </ScrollViewer>
        </Border>

        <!-- ═══════ 内容区：统计概览视图（3天以前） ═══════ -->
        <Border Grid.Row="4" Padding="12"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsTimelineView}" Value="False" />
                                <Condition Binding="{Binding HasData}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="📊 当日统计概览"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,8" />

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center">总活跃时长</TextBlock>
                        <TextBlock Text="{Binding TotalActiveText}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center">事件数</TextBlock>
                        <TextBlock Text="{Binding EventCountText}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center">日期</TextBlock>
                        <TextBlock Text="{Binding DateLabel}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="应用分布"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,6" />

                <ScrollViewer Grid.Row="3"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding AppStats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="core:StatsItem"
                                          xmlns:core="clr-namespace:ActivityMonitor.Core.Interfaces;assembly=ActivityMonitor.Core">
                                <Grid MinHeight="30" Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}">
                                        <Run Text="{Binding DurationMs, StringFormat={}{0:N0}ms}" />
                                        <Run Text=" · " />
                                        <Run Text="{Binding Percentage, StringFormat={}{0:F1}%}" />
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 加载遮罩 -->
        <Border Grid.RowSpan="5" Background="#40FFFFFF">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="加载中..."
                       FontSize="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
