<Window x:Class="ActivityMonitor.TrayApp.ViewDetails.ViewDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="活动详情"
        Height="350" Width="500"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="DetailSection" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="🔍 活动来源追溯"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,12" />

        <!-- 窗口标题 -->
        <Border Grid.Row="1" Style="{StaticResource DetailSection}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="窗口标题"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,4" />
                <TextBlock Grid.Row="1"
                           Text="{Binding WindowTitle}"
                           FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <!-- 进程路径 -->
        <Border Grid.Row="2" Style="{StaticResource DetailSection}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="进程路径"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,4" />
                <TextBlock Grid.Row="1"
                           Text="{Binding ProcessPath}"
                           FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontFamily="Consolas"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <!-- 进程名和 PID -->
        <Border Grid.Row="3" Style="{StaticResource DetailSection}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}">进程名称</TextBlock>
                    <TextBlock Text="{Binding ProcessName}"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}">进程 ID</TextBlock>
                    <TextBlock Text="{Binding ProcessId}"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 时间和时长 -->
        <Border Grid.Row="4" Style="{StaticResource DetailSection}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}">时间段</TextBlock>
                    <TextBlock Text="{Binding StartTime, StringFormat={}{0:HH:mm:ss}}"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}">类别 / 时长</TextBlock>
                    <TextBlock FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Right">
                        <Run Text="{Binding Category}" />
                        <Run Text=" · " />
                        <Run Text="{Binding DurationMs, StringFormat={}{0:N0}ms}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 描述 -->
        <Border Grid.Row="5" Style="{StaticResource DetailSection}"
                x:Name="DetailSection" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="详细描述"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,4" />
                <TextBlock Grid.Row="1"
                           Text="{Binding Detail}"
                           FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <!-- 关闭按钮 -->
        <Button Grid.Row="6"
                Content="关闭"
                Style="{StaticResource PrimaryButton}"
                Background="{StaticResource TextSecondaryBrush}"
                Width="100"
                Height="32"
                Margin="0,8,0,0"
                HorizontalAlignment="Right"
                Click="OnCloseClick" />
    </Grid>
</Window>
