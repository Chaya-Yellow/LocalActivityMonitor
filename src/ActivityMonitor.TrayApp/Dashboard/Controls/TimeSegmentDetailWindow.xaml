<Window x:Class="ActivityMonitor.TrayApp.Dashboard.Controls.TimeSegmentDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="时段活动详情" Height="420" Width="480"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}" ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="DetailSection" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <DataTemplate x:Key="SoftwareItemTemplate">
            <Border Margin="0,2" Padding="8,6" CornerRadius="4"
                    Background="{StaticResource CardBgBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                            Background="{StaticResource AccentBrush}"
                            Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" TextAlignment="Right">
                        <Run Text="{Binding DurationMs, StringFormat={}{0:N0}ms}" />
                        <Run Text=" · " />
                        <Run Text="{Binding Percentage, StringFormat={}{0:F1}%}" />
                    </TextBlock>
                    <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                               Text="{Binding Detail, TargetNullValue=''}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔍 时段活动详情"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" />

        <Border Grid.Row="1" Style="{StaticResource DetailSection}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                           Text="{Binding TimeRangeText}" />
                <TextBlock Grid.Column="2" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                    <Run Text="总活跃 " /><Run Text="{Binding TotalActiveText}" />
                </TextBlock>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,4,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="软件 / 活动"
                       FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Grid.Column="2" Text="时长" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </Grid>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4">
            <ItemsControl ItemsSource="{Binding SoftwareList}"
                          ItemTemplate="{StaticResource SoftwareItemTemplate}"
                          VirtualizingPanel.IsVirtualizing="True" />
        </ScrollViewer>

        <Button Grid.Row="4" Content="关闭" Style="{StaticResource PrimaryButton}"
                Background="{StaticResource TextSecondaryBrush}"
                Width="100" Height="32" Margin="0,8,0,0"
                HorizontalAlignment="Right" Click="OnCloseClick" />
    </Grid>
</Window>
