<UserControl x:Class="ActivityMonitor.TrayApp.Dashboard.Controls.TimelineItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:ActivityMonitor.Core.Models;assembly=ActivityMonitor.Core"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="500"
             x:Name="Root">

    <UserControl.Resources>
        <!-- 各类别的辅助色 -->
        <SolidColorBrush x:Key="CatWebBrush" Color="#0078D4" />
        <SolidColorBrush x:Key="CatFileBrush" Color="#107C10" />
        <SolidColorBrush x:Key="CatAppBrush" Color="#FF8C00" />
        <SolidColorBrush x:Key="CatIdleBrush" Color="#767676" />
        <SolidColorBrush x:Key="CatSleepBrush" Color="#4B0082" />

        <!-- 类别 → 颜色转换 -->
        <Color x:Key="CatWebColor">#0078D4</Color>
        <Color x:Key="CatFileColor">#107C10</Color>
        <Color x:Key="CatAppColor">#FF8C00</Color>
        <Color x:Key="CatIdleColor">#767676</Color>
        <Color x:Key="CatSleepColor">#4B0082</Color>
    </UserControl.Resources>

    <Border Style="{StaticResource CardBorder}"
            Padding="10,8"
            Margin="0,2"
            BorderThickness="0"
            MinHeight="52">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="🔍 查看详情"
                          Command="{Binding ElementName=Root, Path=ViewDetailsCommand}"
                          CommandParameter="{Binding ElementName=Root, Path=EventData}" />
                <Separator />
                <MenuItem Header="✏ 编辑"
                          Command="{Binding ElementName=Root, Path=EditCommand}"
                          CommandParameter="{Binding ElementName=Root, Path=EventData}" />
                <MenuItem Header="🗑 删除"
                          Command="{Binding ElementName=Root, Path=DeleteCommand}"
                          CommandParameter="{Binding ElementName=Root, Path=EventData}" />
                <Separator />
                <MenuItem Header="🚫 标记为误报"
                          Command="{Binding ElementName=Root, Path=MarkAsFalsePositiveCommand}"
                          CommandParameter="{Binding ElementName=Root, Path=EventData}" />
            </ContextMenu>
        </Border.ContextMenu>
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- 类别色条 -->
                <ColumnDefinition Width="4" />
                <!-- 时间 -->
                <ColumnDefinition Width="Auto" />
                <!-- 分隔 -->
                <ColumnDefinition Width="8" />
                <!-- 内容区域 -->
                <ColumnDefinition Width="*" />
                <!-- 时长 -->
                <ColumnDefinition Width="Auto" />
                <!-- 操作按钮 -->
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 类别色条 -->
            <Rectangle Grid.Column="0"
                       Width="4"
                       RadiusX="2" RadiusY="2"
                       Fill="{Binding ElementName=Root, Path=CategoryColor}"
                       VerticalAlignment="Stretch"
                       Margin="0,0,0,0" />

            <!-- 时间区间 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="90">
                <TextBlock Text="{Binding ElementName=Root, Path=StartTimeText}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding ElementName=Root, Path=EndTimeText}"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- 内容区域 -->
            <Grid Grid.Column="3" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 进程名 / 窗口标题 -->
                <TextBlock Grid.Row="0"
                           Text="{Binding ElementName=Root, Path=DisplayTitle}"
                           FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="240" />

                <!-- 项目 / 域名 / 详情 -->
                <TextBlock Grid.Row="1"
                           Text="{Binding ElementName=Root, Path=DetailText}"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="240"
                           Margin="0,1,0,0" />
            </Grid>

            <!-- 时长 -->
            <TextBlock Grid.Column="4"
                       Text="{Binding ElementName=Root, Path=DurationText}"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="8,0,8,0" />

            <!-- 操作按钮 -->
            <StackPanel Grid.Column="5" VerticalAlignment="Center" Orientation="Horizontal">
                <Button Content="✏" ToolTip="编辑"
                        FontSize="11" Width="24" Height="24"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding ElementName=Root, Path=EditCommand}"
                        CommandParameter="{Binding ElementName=Root, Path=EventData}" />
                <Button Content="🗑" ToolTip="删除"
                        FontSize="11" Width="24" Height="24"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="2,0,0,0"
                        Command="{Binding ElementName=Root, Path=DeleteCommand}"
                        CommandParameter="{Binding ElementName=Root, Path=EventData}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
