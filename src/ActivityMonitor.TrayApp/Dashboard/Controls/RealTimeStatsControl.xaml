<UserControl x:Class="ActivityMonitor.TrayApp.Dashboard.Controls.RealTimeStatsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:core="clr-namespace:ActivityMonitor.Core.Interfaces;assembly=ActivityMonitor.Core"
             xmlns:local="clr-namespace:ActivityMonitor.TrayApp.Dashboard.Controls"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="320"
             x:Name="Root">

    <UserControl.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

        <DataTemplate x:Key="StatsItemTemplate" DataType="core:StatsItem">
            <Grid MinHeight="34" Margin="0,2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 第一行：名称 + 时长/占比 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 编辑按钮（仅项目统计显示，点击弹出重命名对话框） -->
                    <Button Grid.Column="0"
                            Content="✎"
                            FontSize="10"
                            Width="16" Height="16"
                            Padding="0"
                            Margin="0,0,3,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Center"
                            ToolTip="重命名项目"
                            Visibility="{Binding Detail,
                                Converter={StaticResource NullToVisibilityConverter}}"
                            Command="{Binding DataContext.RenameProjectCommand,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />

                    <TextBlock Grid.Column="1"
                               Text="{Binding Name}"
                               FontSize="12"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Column="2"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center">
                        <Run Text="{Binding DurationMs, StringFormat={}{0:N0}ms}" />
                        <Run Text=" · " />
                        <Run Text="{Binding Percentage, StringFormat={}{0:F1}%}" />
                    </TextBlock>
                </Grid>

                <!-- 第二行：项目路径（仅当 Detail 非空时显示） -->
                <TextBlock Grid.Row="1"
                           Text="{Binding Detail}"
                           FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           Visibility="{Binding Detail,
                               Converter={StaticResource NullToVisibilityConverter}}"
                           Margin="0,0,0,1" />

                <!-- 第三行：进度条 -->
                <Grid Grid.Row="2" Height="8" Margin="0,2,0,0">
                    <Border Background="#E8E8E8" CornerRadius="4" />
                    <Border Background="{StaticResource AccentBrush}"
                            CornerRadius="4"
                            HorizontalAlignment="Left">
                        <Border.Width>
                            <MultiBinding>
                                <MultiBinding.Converter>
                                    <local:PercentageToWidthConverter />
                                </MultiBinding.Converter>
                                <Binding Path="Percentage" />
                                <Binding Path="ActualWidth"
                                         RelativeSource="{RelativeSource AncestorType=Grid}" />
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{StaticResource CardBorder}" Padding="12,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Row="0"
                       Text="📊 实时统计"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,8" />

            <!-- 视角切换 Tab -->
            <TabControl Grid.Row="1"
                        SelectedIndex="{Binding ElementName=Root, Path=SelectedTab}">
                <TabItem Header="应用" />
                <TabItem Header="项目" />
                <TabItem Header="网页" />
                <TabItem Header="类别" />
            </TabControl>

            <!-- 搜索框 -->
            <Border Grid.Row="2" Margin="0,4,0,2"
                    Background="#F0F0F0"
                    CornerRadius="4"
                    Padding="6,2"
                    BorderThickness="1"
                    BorderBrush="#E0E0E0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="🔍"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" />
                    <TextBox Grid.Column="1"
                             FontSize="12"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             VerticalAlignment="Center"
                             Text="{Binding DataContext.SearchText,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="OnSearchGotFocus"
                             LostFocus="OnSearchLostFocus" />
                </Grid>
            </Border>

            <!-- 列标题（可点击排序） -->
            <Grid Grid.Row="3" Margin="0,6,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 占位列：与编辑按钮对齐 -->
                <TextBlock Grid.Column="0" Width="16" Margin="0,0,3,0" />

                <Button Grid.Column="1"
                        Padding="2,2"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding DataContext.SortByNameCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}">
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="名称" />
                        <Run Text="{Binding DataContext.NameSortGlyph,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   Mode=OneWay}" />
                    </TextBlock>
                </Button>

                <Button Grid.Column="2"
                        Padding="2,2"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding DataContext.SortByDurationCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}">
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="时长" />
                        <Run Text="{Binding DataContext.DurationSortGlyph,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   Mode=OneWay}" />
                    </TextBlock>
                </Button>
            </Grid>

            <!-- 统计列表（分页） -->
            <ScrollViewer Grid.Row="4"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,2,0,0">
                <ItemsControl ItemsSource="{Binding ElementName=Root, Path=PageItems}"
                              ItemTemplate="{StaticResource StatsItemTemplate}" />
            </ScrollViewer>

            <!-- 分页导航栏 -->
            <Border Grid.Row="5"
                    Margin="0,6,0,0"
                    Padding="6,4"
                    CornerRadius="4"
                    Background="#F5F5F5"
                    BorderThickness="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 上一页 -->
                    <Button Grid.Column="0"
                            Content="◀"
                            Padding="6,1"
                            MinWidth="26"
                            FontSize="11"
                            BorderThickness="1"
                            Margin="0,0,4,0"
                            IsEnabled="{Binding ElementName=Root, Path=HasPrevPage}"
                            Click="OnPrevPageClick" />

                    <!-- 页码按钮 -->
                    <ItemsControl Grid.Column="1"
                                  ItemsSource="{Binding ElementName=Root, Path=PageNumbers}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="local:PageNavItem">
                                <Button Content="{Binding DisplayText}"
                                        Command="{Binding ElementName=Root, Path=GoToPageCommand}"
                                        CommandParameter="{Binding Page}"
                                        Padding="6,1"
                                        MinWidth="26"
                                        FontSize="11"
                                        BorderThickness="1"
                                        Margin="1,0"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource TextPrimaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Setter Property="Cursor" Value="Arrow" />
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource TextSecondaryBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter Property="Background"
                                                            Value="{StaticResource AccentBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 下一页 -->
                    <Button Grid.Column="2"
                            Content="▶"
                            Padding="6,1"
                            MinWidth="26"
                            FontSize="11"
                            BorderThickness="1"
                            Margin="4,0,0,0"
                            IsEnabled="{Binding ElementName=Root, Path=HasNextPage}"
                            Click="OnNextPageClick" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
